# ── Ollama ────────────────────────────────────────────────────────────────────
# URL del servidor Ollama (dentro de Docker usa el nombre del servicio)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Modelo LLM principal
OLLAMA_MODEL=qwen2.5:7b

# Modelo de embeddings (deja en blanco o comenta para solo LLM)
#EMBEDDING_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=/app/data/chroma_db

# ── Chunking ──────────────────────────────────────────────────────────────────
# Tamaño máximo de cada chunk en caracteres
CHUNK_SIZE=512

# Solapamiento entre chunks
CHUNK_OVERLAP=64

# ── LLM ───────────────────────────────────────────────────────────────────────
# Temperatura del modelo (0.0 = determinista, 1.0 = creativo)
LLM_TEMPERATURE=0.2

# Ventana de contexto del modelo
LLM_CTX_WINDOW=4096

# ── Seguridad API Keys (colaboradores) ─────────────────────────────────────
# false: sin autenticacion por key
# true: requiere header en endpoints protegidos (/ask, /ingest, /collections)
API_KEY_ENABLED=false

# Lista de keys separadas por coma
# Ejemplo: API_KEYS=key_colab_1,key_colab_2,key_colab_3
API_KEYS=

# Header HTTP para enviar la key
API_KEY_HEADER_NAME=X-API-Key
